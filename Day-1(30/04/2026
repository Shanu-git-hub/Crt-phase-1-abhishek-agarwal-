// celsius to fahrenheit
#include <iostream>
using namespace std;
int main() {
    double celsius, fahrenheit;

    cin >> celsius;

    fahrenheit = (celsius * 9.0 / 5.0) + 32;

    cout << fahrenheit << endl;

    return 0;
}

// Local & Global Variable 
#include <iostream>
using namespace std;

int global_variable = 100;

int main()
{
    int local_variable;
    int result;

    cin >> local_variable;

    result = global_variable / local_variable;

    cout << result << endl;

    return 0;
}

